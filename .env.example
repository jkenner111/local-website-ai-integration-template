# Copy this file to .env.local for local dev (which is git-ignored).
# For production, set these in your hosting provider's environment config.

# ─── Branding ────────────────────────────────────────────────────────────────
# Public (exposed to the browser). Required — drives <title>, header, footer.
NEXT_PUBLIC_SITE_NAME="My Community Site"
NEXT_PUBLIC_SITE_DESCRIPTION="A small community website."
NEXT_PUBLIC_SITE_TAGLINE=""
# Public path to your logo (optional). Drop the file in public/images/.
NEXT_PUBLIC_SITE_LOGO=""

# ─── Events / time display ───────────────────────────────────────────────────
# IANA timezone name. Used to decide "today" when sorting upcoming vs past.
SITE_TIMEZONE="America/New_York"

# ─── Contact form (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=""
# From address — must be a domain you've verified in Resend.
CONTACT_FROM_EMAIL=""
# Optional: "Your Name <you@example.com>" display name. Defaults to SITE_NAME.
CONTACT_FROM_NAME=""
# Comma-separated list of recipients.
CONTACT_TO_EMAILS=""
# Optional: prepended to the email subject, e.g. "[example.com]".
CONTACT_SUBJECT_PREFIX=""

# ─── AI admin portal ─────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint — vLLM, llama.cpp, Ollama, the Anthropic
# or OpenAI API. Leave blank to disable the admin chat.
LLM_BASE_URL=""
LLM_API_KEY=""
LLM_MODEL=""

# Longer description used in the agent's system prompt.
SITE_DESCRIPTION="a small community website managed through this admin portal"

# ─── Admin host routing ──────────────────────────────────────────────────────
# Comma-separated list of hostnames that should only serve the admin UI.
# Example: ADMIN_HOSTS="admin.example.com"
ADMIN_HOSTS=""

# ─── Cloudflare Access (admin auth) ──────────────────────────────────────────
# Required if you expose the /admin route publicly. See lib/cf-access.ts.
CF_ACCESS_TEAM_DOMAIN=""
CF_ACCESS_AUD=""

# Dev-only: bypass CF Access JWT verification and inject a fake admin email.
# NEVER set this in production.
ADMIN_DEV_EMAIL=""
